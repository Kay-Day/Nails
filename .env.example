# Local Node.js development
DATABASE_URL=postgres://postgres:change-me@localhost:5432/nail
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=change-me
PGDATABASE=nail
PORT=3000

# Application secrets (required locally and on the server)
SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# Docker server deployment (see DEPLOY.md)
DOMAIN=nails.example.com
POSTGRES_DB=nail
POSTGRES_USER=nail
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
# Set false only when testing the server over plain HTTP/IP.
SESSION_COOKIE_SECURE=true
