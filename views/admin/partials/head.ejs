<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · Admin</title>
  <link rel="stylesheet" href="/css/admin.css" />
  <link rel="stylesheet" href="/css/site.css" />
  <script src="/js/admin.js" defer></script>
</head>
<body>
<div class="admin">
  <aside class="sidebar">
    <div class="sidebar__mobile-head">
      <div class="sidebar__brand"><%= settings.shop_name || 'Majestic Nail Care' %> admin</div>
      <button class="sidebar__toggle" type="button" aria-controls="admin-navigation" aria-expanded="false" aria-label="Open admin menu">
        <span></span><span></span><span></span>
      </button>
    </div>
    <nav id="admin-navigation">
      <a href="/admin" class="<%= active==='dashboard'?'active':'' %>"><%- include('icon', { name: 'dashboard' }) %><span>Dashboard</span></a>
      <a href="/admin/products" class="<%= active==='products'?'active':'' %>"><%- include('icon', { name: 'products' }) %><span>Products</span></a>
      <a href="/admin/collections" class="<%= active==='collections'?'active':'' %>"><%- include('icon', { name: 'collections' }) %><span>Collections</span></a>
      <a href="/admin/filters" class="<%= active==='filters'?'active':'' %>"><%- include('icon', { name: 'collections' }) %><span>Categories</span></a>
      <a href="/admin/banners" class="<%= active==='banners'?'active':'' %>"><%- include('icon', { name: 'banners' }) %><span>Banners</span></a>
      <a href="/admin/posts" class="<%= active==='posts'?'active':'' %>"><%- include('icon', { name: 'blog' }) %><span>Blog</span></a>
      <a href="/admin/settings" class="<%= active==='settings'?'active':'' %>"><%- include('icon', { name: 'settings' }) %><span>Settings</span></a>
    </nav>
    <div class="sidebar__foot">
      <a href="/" target="_blank" class="sidebar__store-link"><%- include('icon', { name: 'store', size: 16 }) %><span>View store</span></a><br/><br/>
      <span style="color:#fff"><%= admin ? admin.username : '' %></span> ·
      <form action="/admin/logout" method="post" style="display:inline"><button type="submit" class="sidebar__logout"><%- include('icon', { name: 'logout', size: 15 }) %><span>Logout</span></button></form>
    </div>
  </aside>
  <main class="main">
    <div class="topbar">
      <h1><%= title %></h1>
      <div><%= typeof headerAction !== 'undefined' ? '' : '' %></div>
    </div>
    <div class="content">
