<%- include('partials/head') %>

<form class="form-card" method="post" action="<%= formAction %>" enctype="multipart/form-data">
  <div class="form-grid">
    <div class="form-row form-row--full">
      <label>Title</label>
      <input type="text" name="title" value="<%= banner.title || '' %>" />
    </div>
    <div class="form-row form-row--full">
      <label>Subtitle</label>
      <textarea name="subtitle" rows="2"><%= banner.subtitle || '' %></textarea>
    </div>
    <div class="form-row">
      <label>Button text</label>
      <input type="text" name="button_text" value="<%= banner.button_text || '' %>" placeholder="Shop Now" />
    </div>
    <div class="form-row">
      <label>Link</label>
      <input type="text" name="link" value="<%= banner.link || '' %>" placeholder="/products" />
    </div>
    <%- include('partials/media-field', {
      label: 'Background image',
      kind: 'image',
      currentUrl: banner.image || '',
      fileName: 'image',
      urlName: 'image_url',
      removeName: 'remove_image',
      accept: 'image/*',
      placeholder: 'https://example.com/banner.jpg',
      hint: 'Choose a wide image from this device or paste a direct image link.'
    }) %>
    <%- include('partials/media-field', {
      label: 'Background video',
      kind: 'video',
      currentUrl: banner.video || '',
      fileName: 'video',
      urlName: 'video_url',
      removeName: 'remove_video',
      accept: 'video/mp4,video/webm',
      placeholder: 'YouTube, Vimeo, MP4, or WebM URL',
      hint: 'Optional. A video replaces the background image when available.'
    }) %>
    <div class="form-row">
      <label>Sort order</label>
      <input type="number" name="sort_order" value="<%= banner.sort_order || 0 %>" />
    </div>
    <div class="form-row">
      <label class="check"><input type="checkbox" name="is_active" <%= (banner.is_active===undefined||banner.is_active)?'checked':'' %> /> Active</label>
    </div>
  </div>
  <div class="form-actions">
    <button type="submit" class="btn btn--primary">Save Banner</button>
    <a href="/admin/banners" class="btn btn--ghost">Cancel</a>
  </div>
</form>

<%- include('partials/foot') %>
