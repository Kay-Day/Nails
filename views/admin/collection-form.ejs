<%- include('partials/head') %>

<form class="form-card" method="post" action="<%= formAction %>" enctype="multipart/form-data">
  <div class="form-grid">
    <div class="form-row form-row--full">
      <label>Title</label>
      <input type="text" name="title" value="<%= collection.title || '' %>" required />
    </div>
    <div class="form-row form-row--full">
      <label>Slug <span class="hint">leave blank to auto-generate from title</span></label>
      <input type="text" name="slug" value="<%= collection.slug || '' %>" placeholder="e.g. almond" />
    </div>
    <div class="form-row form-row--full">
      <label>Description</label>
      <textarea name="description" rows="3"><%= collection.description || '' %></textarea>
    </div>
    <%- include('partials/media-field', {
      label: 'Image',
      kind: 'image',
      currentUrl: collection.image || '',
      fileName: 'image',
      urlName: 'image_url',
      removeName: 'remove_image',
      accept: 'image/*',
      placeholder: 'https://example.com/collection.jpg',
      hint: 'Choose a file from this device or paste a direct image link.'
    }) %>
    <div class="form-row">
      <label>Sort order</label>
      <input type="number" name="sort_order" value="<%= collection.sort_order || 0 %>" />
    </div>
    <div class="form-row">
      <label class="check"><input type="checkbox" name="is_active" <%= (collection.is_active===undefined||collection.is_active)?'checked':'' %> /> Active</label>
    </div>
  </div>
  <div class="form-actions">
    <button type="submit" class="btn btn--primary">Save Collection</button>
    <a href="/admin/collections" class="btn btn--ghost">Cancel</a>
  </div>
</form>

<%- include('partials/foot') %>
