<%- include('partials/head') %>

<div class="panel">
  <div class="panel__head">
    <h2><%= banners.length %> Banners</h2>
    <a href="/admin/banners/new" class="btn btn--accent btn--sm">+ New Banner</a>
  </div>
  <table>
    <thead><tr><th></th><th>Title</th><th>Link</th><th>Order</th><th>Status</th><th></th></tr></thead>
    <tbody>
      <% if (!banners.length) { %><tr><td colspan="6" class="empty-row">No banners yet.</td></tr><% } %>
      <% banners.forEach(function(b) { %>
        <tr>
          <td><img class="thumb thumb--wide" src="<%= b.image || '/images/Website_Photos_Square.jpg' %>" /></td>
          <td><%= b.title || '—' %><% if (b.video) { %> <span class="badge badge--on">video</span><% } %></td>
          <td><small><%= b.link || '—' %></small></td>
          <td><%= b.sort_order %></td>
          <td><span class="badge badge--<%= b.is_active ? 'on':'off' %>"><%= b.is_active ? 'Active':'Hidden' %></span></td>
          <td class="actions">
            <a href="/admin/banners/<%= b.id %>/edit" class="btn btn--ghost btn--sm">Edit</a>
            <form action="/admin/banners/<%= b.id %>/delete" method="post" onsubmit="return confirm('Delete this banner?')">
              <button class="btn btn--danger btn--sm" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('partials/foot') %>
