<%- include('partials/head') %>

<form class="form-card" method="post" action="<%= formAction %>" enctype="multipart/form-data">
  <div class="form-grid">
    <div class="form-row"><label>Eyebrow</label><input name="eyebrow" value="<%= section.eyebrow || '' %>" /></div>
    <div class="form-row"><label>Title</label><input name="title" value="<%= section.title || '' %>" /></div>
    <div class="form-row form-row--full"><label>Subtitle</label><textarea name="subtitle" rows="3"><%= section.subtitle || '' %></textarea></div>
    <%- include('partials/rich-editor', {
      label: 'Content',
      name: 'body_html',
      value: section.body_html || '',
      hint: 'Write and format the text as it should appear on the website.'
    }) %>
    <%- include('partials/media-field', {
      label: 'Image',
      kind: 'image',
      currentUrl: section.image || '',
      fileName: 'image',
      urlName: 'image_url',
      removeName: 'remove_image',
      accept: 'image/*',
      placeholder: 'https://example.com/photo.jpg',
      hint: 'Choose a file from this device or paste a direct image link.'
    }) %>
    <div class="form-row"><label>Button text</label><input name="button_text" value="<%= section.button_text || '' %>" /></div>
    <div class="form-row"><label>Button link</label><input name="button_link" value="<%= section.button_link || '' %>" /></div>
    <div class="form-row form-row--full">
      <label>Curated products <span class="hint">used by product sections; Ctrl/Cmd-click to select multiple</span></label>
      <select name="product_ids" multiple size="10">
        <% products.forEach(function(product) { %><option value="<%= product.id %>" <%= productIds.includes(product.id) ? 'selected' : '' %>><%= product.title %></option><% }) %>
      </select>
    </div>
    <div class="form-row"><label class="check"><input type="checkbox" name="is_active" <%= section.is_active === undefined || section.is_active ? 'checked' : '' %> /> Active</label></div>
    <details class="admin-advanced form-row form-row--full">
      <summary>Advanced settings</summary>
      <div class="admin-advanced__grid">
        <div class="form-row"><label>Page</label><input name="page_slug" value="<%= section.page_slug || 'home' %>" placeholder="home" required /></div>
        <div class="form-row"><label>Section key</label><input name="section_key" value="<%= section.section_key || '' %>" placeholder="best-sellers" required /></div>
        <div class="form-row"><label>Section type</label><input name="section_type" value="<%= section.section_type || 'content' %>" placeholder="content" /></div>
        <div class="form-row"><label>Sort order</label><input type="number" name="sort_order" value="<%= section.sort_order || 0 %>" /></div>
      </div>
    </details>
  </div>
  <div class="form-actions"><button class="btn btn--primary" type="submit">Save Section</button><a href="/admin/content" class="btn btn--ghost">Back</a></div>
</form>

<% if (section.id) { %>
<div class="panel" style="margin-top:24px">
  <div class="panel__head"><h2>Section Items</h2><a href="/admin/content/<%= section.id %>/items/new" class="btn btn--accent btn--sm">+ New Item</a></div>
  <table>
    <thead><tr><th>Label</th><th>Title</th><th>Link</th><th>Order</th><th>Status</th><th></th></tr></thead>
    <tbody>
      <% if (!section.items.length) { %><tr><td colspan="6" class="empty-row">This section has no repeated items.</td></tr><% } %>
      <% section.items.forEach(function(item) { %><tr><td><%= item.label || '-' %></td><td><%= item.title || '-' %></td><td><code><%= item.link || '-' %></code></td><td><%= item.sort_order %></td><td><span class="badge badge--<%= item.is_active ? 'on' : 'off' %>"><%= item.is_active ? 'Active' : 'Hidden' %></span></td><td class="actions"><a class="btn btn--ghost btn--sm" href="/admin/content/items/<%= item.id %>/edit">Edit</a><form method="post" action="/admin/content/items/<%= item.id %>/delete" onsubmit="return confirm('Delete this item?')"><button class="btn btn--danger btn--sm" type="submit">Delete</button></form></td></tr><% }) %>
    </tbody>
  </table>
</div>
<% } %>

<%- include('partials/foot') %>
