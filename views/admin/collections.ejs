<%- include('partials/head') %>

<div class="panel">
  <div class="panel__head">
    <h2><%= collections.length %> Collections</h2>
    <a href="/admin/collections/new" class="btn btn--accent btn--sm">+ New Collection</a>
  </div>
  <table>
    <thead><tr><th></th><th>Title</th><th>Slug</th><th>Products</th><th>Order</th><th>Status</th><th></th></tr></thead>
    <tbody>
      <% if (!collections.length) { %><tr><td colspan="7" class="empty-row">No collections yet.</td></tr><% } %>
      <% collections.forEach(function(c) { %>
        <tr>
          <td><img class="thumb" src="<%= c.image || '/images/Website_Photos_Square.jpg' %>" /></td>
          <td><%= c.title %></td>
          <td><code><%= c.slug %></code></td>
          <td><%= c.product_count %></td>
          <td><%= c.sort_order %></td>
          <td><span class="badge badge--<%= c.is_active ? 'on':'off' %>"><%= c.is_active ? 'Active':'Hidden' %></span></td>
          <td class="actions">
            <a href="/admin/collections/<%= c.id %>/edit" class="btn btn--ghost btn--sm">Edit</a>
            <form action="/admin/collections/<%= c.id %>/delete" method="post" onsubmit="return confirm('Delete collection? Products will be unassigned.')">
              <button class="btn btn--danger btn--sm" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('partials/foot') %>
